# Copy this file to ".env" and fill in the values below.
# All of these are client-side / public values (they ship in the browser
# bundle), so they're env vars for configurability, not secrecy.

# Persistent submission-counter worker URL. See worker/README.md.
VITE_COUNTER_URL=

# EmailJS contact form config. From your EmailJS dashboard:
#   Service ID  -> Email Services
#   Template ID -> Email Templates
#   Public Key  -> Account > General
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
